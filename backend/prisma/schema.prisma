// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role{
    AGENT
    CHEF
}

enum Habilitation{
    CONFIDENTIEL
    SECRET
    TRES_SECRET
}

enum StatutMission{
    DISPONIBLE
    EN_COURS
    REUSSIE
    ECHOUEE
}

model Agent{
    id              String @id @default(uuid())
    username        String @unique
    email           String
    mdp             String
    role            Role @default(AGENT)
    habilitation    Habilitation @default(CONFIDENTIEL)
    nom             String
    nationalite     String
    photo           String
    createdAt       DateTime @default(now())
    missions        Mission[]
}

model Mission{
    id                  Int @id @default(autoincrement())
    titre               String
    description         String
    nivConfidentialite  Habilitation @default(CONFIDENTIEL)
    statut              StatutMission @default(DISPONIBLE)
    recompense          String
    createdAt           DateTime @default(now())
    agentId             String?
    agent               Agent? @relation(fields:[agentId], references: [id])  
}